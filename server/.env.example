# MongoDB Atlas connection string
# Get this from: Atlas Dashboard → Connect → Drivers → Copy connection string
# Replace <username>, <password>, and <dbname> with your values
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/svs-grands?retryWrites=true&w=majority

# Server port
PORT=5000

# Frontend URL (for CORS — set this to your Vercel deployment URL)
# CLIENT_URL=https://svs-grands.vercel.app
